@model IEnumerable<EmployeeManagement.Models.Employee>
@using Microsoft.AspNetCore.Http

@{
    string? role =
        Context.Session.GetString("Role");
}

@{
    ViewData["Title"] = "Employee List";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white p-3">

            <div class="d-flex justify-content-between align-items-center flex-wrap">

                <div>
                    <h4 class="mb-1">
                        <i class="bi bi-people-fill"></i>
                        @(ViewData["PageTitle"] ?? "Employee List")
                    </h4>

                    <small class="opacity-75">
                        Manage employee records, status, and analytics
                    </small>
                </div>

                <span class="badge bg-light text-dark fs-6 px-3 py-2">
                    Total: @ViewBag.TotalRecords
                </span>

            </div>

        </div>

        <div class="card-body">
            <div class="row g-3 mb-4">

                @if (role != "Manager" && role != "User")
                {
                    <div class="col-lg-3">
                        <button type="button"
                                class="btn btn-success w-100"
                                onclick="openEmployeeModal('/Employee/Create')">

                            <i class="bi bi-plus-circle"></i>
                            Create Employee
                        </button>
                    </div>
                }

                <div class="col-lg-3">
                    <a asp-action="ExportToExcel"
                    class="btn btn-primary w-100">
                        <i class="bi bi-file-earmark-excel"></i>
                        Export Excel
                    </a>
                </div>

                <div class="col-lg-3">
                    <a asp-action="ExportToPdf"
                    class="btn btn-danger w-100">
                        <i class="bi bi-file-earmark-pdf"></i>
                        Export PDF
                    </a>
                </div>

            </div>

            <form method="get" class="row g-3 mb-4 align-items-end">

                <div class="col-md-3">

                    <input type="text"
                        name="searchString"
                        class="form-control"
                        placeholder="Search..."
                        value="@ViewData["CurrentFilter"]" />

                </div>

                <div class="col-md-3">

                    <select name="departmentFilter"
                            class="form-select">

                        <option value="">
                            All Departments
                        </option>

                        @foreach (var dept in ViewBag.Departments)
                        {
                            <option value="@dept">
                                @dept
                            </option>
                        }

                    </select>

                </div>

                <div class="col-md-2">

                    <select name="monthFilter"
                            class="form-select">

                        <option value="">
                            All Months
                        </option>

                        @for (int i = 1; i <= 12; i++)
                        {
                            <option value="@i">
                                @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                            </option>
                        }

                    </select>

                </div>

                <div class="col-md-2">

                    <select name="weekFilter"
                            class="form-select">

                        <option value="">
                            All Weeks
                        </option>

                        <option value="CurrentWeek">
                            Current Week
                        </option>

                    </select>

                </div>

                <div class="col-md-2">

                    <button type="submit"
                            class="btn btn-primary">

                        Filter

                    </button>

                    <a asp-action="Index"
                        class="btn btn-secondary">
                            Clear
                    </a>

                </div>

            </form>

            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Employee Code</th>
                        <th>Employee Name</th>
                        <th>Department</th>
                        <th>Gender</th>
                        <th>Date Of Birth</th>
                        <th>Salary</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var employee in Model)
                    {
                        <tr>
                            <td>@employee.EmployeeCode</td>
                            <td>@employee.EmployeeName</td>
                            <td>@employee.Department?.DepartmentName</td>
                            <td>@employee.Gender</td>
                            <td>@employee.DateOfBirth.ToString("dd-MMM-yyyy")</td>
                            <td>@employee.Salary.ToString("N2")</td>
                            <td>
                                @if (employee.IsActive)
                                {
                                    <span class="badge bg-success">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Inactive
                                    </span>
                                }
                            </td>

                            <td class="text-nowrap">

                                <button type="button"
                                        class="btn btn-info btn-sm"
                                        onclick="openEmployeeModal('/Employee/Details/@employee.EmployeeId')">
                                        <i class="bi bi-info-lg"></i>

                                    Details

                                </button>

                                @if (role != "Manager" && role != "User")
                                {
                                    <button type="button"
                                            class="btn btn-warning btn-sm"
                                            onclick="openEmployeeModal('/Employee/Edit/@employee.EmployeeId')">
                                            <i class="bi bi-pencil-square"></i>

                                        Edit

                                    </button>
                                }

                                @if (role != "Manager" && role != "User")
                                @if (employee.IsActive)
                                {
                                    <button type="button"
                                            class="btn btn-danger btn-sm"
                                            onclick="openEmployeeStatusModal(
                                                '@employee.EmployeeId',
                                                '@employee.EmployeeName',
                                                'inactivate')">

                                        <i class="bi bi-person-x"></i>
                                        Inactivate

                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="btn btn-success btn-sm"
                                            onclick="openEmployeeStatusModal(
                                                '@employee.EmployeeId',
                                                '@employee.EmployeeName',
                                                'activate')">

                                        <i class="bi bi-person-check"></i>
                                        Activate

                                    </button>
                                }

                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <nav>

                <ul class="pagination justify-content-center">

                    @if (ViewBag.CurrentPage > 1)
                    {
                        <li class="page-item">

                            <a class="page-link"
                                asp-action="Index"
                                asp-route-page="@(ViewBag.CurrentPage - 1)"
                                asp-route-searchString="@ViewData["CurrentFilter"]"
                                asp-route-genderFilter="@ViewBag.GenderFilter"
                                asp-route-departmentFilter="@ViewBag.DepartmentFilter"
                                asp-route-monthFilter="@ViewBag.MonthFilter">

                                    Previous

                            </a>

                        </li>
                    }

                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item
                            @(i == ViewBag.CurrentPage
                                ? "active"
                                : "")">

                            <a class="page-link"
                                asp-action="Index"
                                asp-route-page="@i"
                                asp-route-searchString="@ViewData["CurrentFilter"]"
                                asp-route-genderFilter="@ViewBag.GenderFilter"
                                asp-route-departmentFilter="@ViewBag.DepartmentFilter"
                                asp-route-monthFilter="@ViewBag.MonthFilter">

                                    @i

                            </a>

                        </li>
                    }

                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <li class="page-item">

                            <a class="page-link"
                                asp-action="Index"
                                asp-route-page="@(ViewBag.CurrentPage + 1)"
                                asp-route-searchString="@ViewData["CurrentFilter"]"
                                asp-route-genderFilter="@ViewBag.GenderFilter"
                                asp-route-departmentFilter="@ViewBag.DepartmentFilter"
                                asp-route-monthFilter="@ViewBag.MonthFilter"
                                asp-route-weekFilter="@ViewBag.WeekFilter">

                                Next

                            </a>

                        </li>
                    }

                </ul>

            </nav>
        </div>
    </div>
</div>



<div class="modal fade"
     id="employeeModal"
     tabindex="-1">

    <div class="modal-dialog modal-lg modal-dialog-scrollable">

        <div class="modal-content"
             id="employeeModalContent">

        </div>

    </div>

</div>

<div class="modal fade"
     id="employeeStatusModal"
     tabindex="-1">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header bg-warning text-dark">

                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle"></i>
                    Confirm Employee Status
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <form asp-action="ToggleStatus"
                  method="post">

                @Html.AntiForgeryToken()

                <div class="modal-body">

                    <input type="hidden"
                           name="id"
                           id="statusEmployeeId" />

                    <input type="hidden"
                           name="page"
                           value="@ViewBag.CurrentPage" />

                    <input type="hidden"
                           name="searchString"
                           value="@ViewData["CurrentFilter"]" />

                    <input type="hidden"
                           name="genderFilter"
                           value="@ViewBag.GenderFilter" />

                    <input type="hidden"
                           name="departmentFilter"
                           value="@ViewBag.DepartmentFilter" />

                    <input type="hidden"
                           name="monthFilter"
                           value="@ViewBag.MonthFilter" />

                    <input type="hidden"
                           name="weekFilter"
                           value="@ViewBag.WeekFilter" />

                    <p class="mb-0"
                       id="employeeStatusMessage">
                    </p>

                </div>

                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">

                        <i class="bi bi-x-circle"></i>
                        No, Cancel

                    </button>

                    <button type="submit"
                            class="btn btn-primary"
                            id="employeeStatusConfirmButton">

                        <i class="bi bi-check-circle"></i>
                        Yes, Continue

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>

        function openEmployeeModal(url)
        {
            $.ajax({
                url: url,
                type: 'GET',

                success: function (data)
                {
                    $("#employeeModalContent")
                        .html(data);

                    var modal =
                        new bootstrap.Modal(
                            document.getElementById(
                                'employeeModal'));

                    modal.show();

                    $.validator.unobtrusive.parse(
                        "#employeeModalContent");
                },

                error: function ()
                {
                    alert("Failed to load modal.");
                }
            });
        }

        function showToast(message)
        {
            $("#toastMessage").text(message);

            var toast =
                new bootstrap.Toast(
                    document.getElementById('liveToast'));

            toast.show();
        }

        $(document).on(
            "submit",
            "#createEmployeeForm",
            function (e)
            {
                e.preventDefault();

                const submitButton =
                    $(this).find("button[type='submit']");

                submitButton.prop("disabled", true);
                submitButton.text("Saving...");

                $.ajax({
                    url: '/Employee/Create',
                    type: 'POST',
                    data: $(this).serialize(),

                    success: function (response)
                    {
                        if (response.success)
                        {
                            window.location.href = "/Employee/Index";
                        }
                        else
                        {
                            $("#employeeModalContent")
                                .html(response);

                            submitButton.prop("disabled", false);
                            submitButton.text("Save Employee");
                        }
                    },

                    error: function ()
                    {
                        submitButton.prop("disabled", false);
                        submitButton.text("Save Employee");

                        alert("Create failed.");
                    }
                });
            });

        function showToast(message)
        {
            $("#toastMessage").text(message);

            var toast =
                new bootstrap.Toast(
                    document.getElementById('liveToast'));

            toast.show();
        }

        $(document).on(
            "submit",
            "#editEmployeeForm",
            function (e)
            {
                e.preventDefault();

                $.ajax({
                    url: '/Employee/Edit',
                    type: 'POST',
                    data: $(this).serialize(),

                    success: function (response)
                    {
                        if (response.success)
                        {
                            window.location.href = "/Employee/Index";
                        }
                        else
                        {
                            showToast("Failed to update employee.");
                            $("#employeeModalContent")
                                .html(response);
                        }
                    },

                    error: function (xhr)
                    {
                        console.log(xhr.responseText);

                        alert("Edit failed.");
                    }
                });
            });

        function showToast(message)
        {
            $("#toastMessage").text(message);

            var toast =
                new bootstrap.Toast(
                    document.getElementById('liveToast'));

            toast.show();
        }

        $(document).on(
            "submit",
            "#deleteEmployeeForm",
            function (e)
            {
                e.preventDefault();

                $.ajax({
                    url: '/Employee/DeleteConfirmed',
                    type: 'POST',
                    data: $(this).serialize(),

                    success: function (response)
                    {
                        if (response.success)
                        {
                            showToast("Employee deleted successfully.");
                            setTimeout(function ()
                            {
                                location.reload();
                            }, 1000);
                        }
                    },

                    error: function ()
                    {
                        alert("Delete failed.");
                    }
                });
            });

            function openEmployeeStatusModal(employeeId, employeeName, actionType)
            {
                document.getElementById("statusEmployeeId")
                    .value = employeeId;

                document.getElementById("employeeStatusMessage")
                    .innerText =
                        "Are you sure you want to " +
                        actionType +
                        " employee '" +
                        employeeName +
                        "'?";

                const confirmButton =
                    document.getElementById("employeeStatusConfirmButton");

                if (actionType === "inactivate") {
                    confirmButton.className = "btn btn-danger";
                }
                else {
                    confirmButton.className = "btn btn-success";
                }

                var modal =
                    new bootstrap.Modal(
                        document.getElementById("employeeStatusModal"));

                modal.show();
            }

    </script>
}