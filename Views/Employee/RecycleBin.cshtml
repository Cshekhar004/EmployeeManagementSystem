@model IEnumerable<EmployeeManagement.Models.Employee>

@{
    ViewData["Title"] = "Recycle Bin";
}

<h3>Deleted Employees</h3>

<div class="mb-3">

    <a asp-action="Index"
       class="btn btn-secondary">

        <i class="bi bi-arrow-left"></i>

        Back to Employee List

    </a>

</div>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>Code</th>
            <th>Name</th>
            <th>Department</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>

        @if (Model.Any())
        {
            @foreach (var employee in Model)
            {
                <tr>

                    <td>@employee.EmployeeCode</td>

                    <td>@employee.EmployeeName</td>

                    <td>@employee.Department?.DepartmentName</td>

                    <td>@employee.Gender</td>

                    <td>
                        @employee.DateOfBirth.ToString("dd-MMM-yyyy")
                    </td>

                    <td>
                        @employee.Salary.ToString("N2")
                    </td>

                    <td>

                        <form asp-action="Restore"
                            asp-route-id="@employee.EmployeeId"
                            method="post"
                            style="display:inline;">

                            <button type="submit"
                                    class="btn btn-success btn-sm">

                                <i class="bi bi-arrow-counterclockwise"></i>

                                Restore

                            </button>

                        </form>

                        <form asp-action="PermanentDelete"
                            asp-route-id="@employee.EmployeeId"
                            method="post"
                            style="display:inline;">

                            <button type="submit"
                                    class="btn btn-danger btn-sm">

                                <i class="bi bi-trash"></i>

                                Delete

                            </button>

                        </form>

                    </td>

                </tr>
            }
        }
        else
        {
            <tr>

                <td colspan="7"
                    class="text-center text-muted py-4">

                    <i class="bi bi-trash3 fs-1"></i>

                    <br />

                    Recycle Bin is empty

                </td>

            </tr>
        }

    </tbody>

</table>