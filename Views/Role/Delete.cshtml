@model EmployeeManagement.Models.Role

@{
    Layout = null;
}

@{
    ViewData["Title"] = "Delete Role";
}

<div class="container mt-4">

    <div class="card shadow border-danger">

        <div class="card-header bg-danger text-white">
            <h4>Delete Role</h4>
        </div>

        <div class="card-body">

            <h5>
                Are you sure you want to delete this role?
            </h5>

            <hr />

            <p><strong>Role Id:</strong> @Model.RoleId</p>

            <p><strong>Role Name:</strong> @Model.RoleName</p>

            <p><strong>Description:</strong> @Model.Description</p>

            <form asp-action="Delete"
                  method="post">

                <input type="hidden"
                       name="id"
                       value="@Model.RoleId" />

                <button type="submit"
                        class="btn btn-danger">
                    Confirm Delete
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Cancel
                </a>

            </form>

        </div>

    </div>

</div>