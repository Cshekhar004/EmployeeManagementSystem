@model IEnumerable<EmployeeManagement.Models.Role>

@{
    ViewData["Title"] = "Role Management";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white p-3">

            <div class="d-flex justify-content-between align-items-center flex-wrap">

                <div>
                    <h4 class="mb-1">
                        <i class="bi bi-shield-lock-fill"></i>
                        Role Management
                    </h4>

                    <small class="opacity-75">
                        Manage system roles and access levels
                    </small>
                </div>

                <span class="badge bg-light text-dark fs-6 px-3 py-2">
                    Total: @ViewBag.TotalRecords
                </span>

            </div>

        </div>

        <div class="card-body">

            <div class="row mb-4 g-3 align-items-center">

                <div class="col-lg-3">

                    <button type="button"
                            class="btn btn-success w-100"
                            onclick="openRoleModal('/Role/Create')">

                        <i class="bi bi-plus-circle"></i>
                        Create Role

                    </button>

                </div>

                <div class="col-lg-9">

                    <form method="get">

                        <div class="input-group">

                            <span class="input-group-text">
                                <i class="bi bi-search"></i>
                            </span>

                            <input type="text"
                                name="searchString"
                                class="form-control"
                                placeholder="Search by role name or description..."
                                value="@ViewData["CurrentFilter"]" />

                            <button type="submit"
                                    class="btn btn-primary">
                                Search
                            </button>

                            <a asp-action="Index"
                            class="btn btn-secondary">
                                Clear
                            </a>

                        </div>

                    </form>

                </div>

            </div> 

            <div class="table-responsive">

                <table class="table table-bordered table-hover">

                    <thead class="table-dark">
                        <tr>
                            <th><a class="text-white text-decoration-none" asp-action="Index" asp-route-sortOrder="roleid_desc" asp-route-searchString="@ViewData["CurrentFilter"]">Role Id</a></th>
                            <th><a class="text-white text-decoration-none" asp-action="Index" asp-route-sortOrder="rolename" asp-route-searchString="@ViewData["CurrentFilter"]">Role Name</a></th>
                            <th>Description</th>
                            <th><a class="text-white text-decoration-none" asp-action="Index" asp-route-sortOrder="created" asp-route-searchString="@ViewData["CurrentFilter"]">Created Date</a></th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model.Any())
                        {
                            foreach (var role in Model)
                            {
                                <tr>
                                    <td>@role.RoleId</td>

                                    <td>@role.RoleName</td>

                                    <td>@role.Description</td>

                                    <td>
                                        @role.CreatedDate.ToString("dd-MMM-yyyy")
                                    </td>

                                    <td>
                                        <button type="button"
                                                class="btn btn-info btn-sm"
                                                onclick="openRoleModal('/Role/Details/@role.RoleId')">

                                            <i class="bi bi-eye"></i>
                                            Details

                                        </button>

                                        <button type="button"
                                                class="btn btn-warning btn-sm"
                                                onclick="openRoleModal('/Role/Edit/@role.RoleId')">

                                            <i class="bi bi-pencil-square"></i>
                                            Edit

                                        </button>

                                        <button type="button"
                                                class="btn btn-danger btn-sm"
                                                onclick="openRoleModal('/Role/Delete/@role.RoleId')">

                                            <i class="bi bi-trash"></i>
                                            Delete

                                        </button>
                                        
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5"
                                    class="text-center text-muted py-4">
                                    No roles found.
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

            <nav>
                <ul class="pagination justify-content-center">

                    @if (ViewBag.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(ViewBag.CurrentPage - 1)"
                               asp-route-searchString="@ViewData["CurrentFilter"]">
                                Previous
                            </a>
                        </li>
                    }

                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">

                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-searchString="@ViewData["CurrentFilter"]">
                                @i
                            </a>

                        </li>
                    }

                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(ViewBag.CurrentPage + 1)"
                               asp-route-searchString="@ViewData["CurrentFilter"]">
                                Next
                            </a>
                        </li>
                    }

                </ul>
            </nav>

        </div>

    </div>

</div>

<div class="modal fade"
     id="roleModal"
     tabindex="-1">

    <div class="modal-dialog modal-lg modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header bg-primary text-white">

                <h5 class="modal-title">
                    Role Management
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body"
                 id="roleModalBody">
            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <script>
        function openRoleModal(url)
        {
            fetch(url)
                .then(response => response.text())
                .then(html =>
                {
                    document.getElementById("roleModalBody")
                        .innerHTML = html;

                    var modal =
                        new bootstrap.Modal(
                            document.getElementById("roleModal"));

                    modal.show();
                });
        }

        document.addEventListener("submit", function (e) {

            if (e.target && e.target.id === "createRoleForm") {
                e.preventDefault();

                const form = e.target;
                const formData = new FormData(form);

                fetch(form.action, {
                    method: "POST",
                    body: formData
                })
                .then(async response => {

                    const contentType =
                        response.headers.get("content-type");

                    if (contentType &&
                        contentType.includes("application/json")) {

                        const result =
                            await response.json();

                        if (result.success) {
                            location.reload();
                        }
                    }
                    else {
                        const html =
                            await response.text();

                        document.getElementById("roleModalBody")
                            .innerHTML = html;
                    }
                });
            }

            if (e.target && e.target.id === "editRoleForm") {
                e.preventDefault();

                const form = e.target;
                const formData = new FormData(form);

                fetch(form.action, {
                    method: "POST",
                    body: formData
                })
                .then(async response => {

                    const contentType =
                        response.headers.get("content-type");

                    if (contentType &&
                        contentType.includes("application/json")) {

                        const result =
                            await response.json();

                        if (result.success) {
                            location.reload();
                        }
                    }
                    else {
                        const html =
                            await response.text();

                        document.getElementById("roleModalBody")
                            .innerHTML = html;
                    }
                });
            }

        });

    </script>
}