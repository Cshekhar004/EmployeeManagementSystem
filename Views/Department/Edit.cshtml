@model EmployeeManagement.Models.Department

<form id="editDepartmentForm">

    <input type="hidden"
           asp-for="DepartmentId" />

    <div class="mb-3">

        <label class="form-label">
            Department Name
        </label>

        <input asp-for="DepartmentName"
               class="form-control" />

        <span asp-validation-for="DepartmentName"
              class="text-danger">
        </span>

    </div>

    <button type="submit"
            class="btn btn-warning">

        Update

    </button>

</form>

<partial name="_ValidationScriptsPartial" />