@model EmployeeManagement.Models.ViewModels.EditUserViewModel

@{
    Layout = null;
}

@{
    ViewData["Title"] = "Edit User";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-warning">
            <h4>Edit User</h4>
        </div>

        <div class="card-body">

            <form id="editUserForm"
                asp-action="Edit"
                method="post">

                <input asp-for="UserId" type="hidden" />

                <div class="mb-3">
                    <label>Name</label>
                    <input asp-for="Name"
                           class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Username</label>
                    <input asp-for="Username"
                           class="form-control"
                           readonly />
                </div>

                <div class="mb-3">
                    <label>Email</label>
                    <input asp-for="Email"
                           class="form-control" />
                </div>

                <div class="mb-3">
                <label>
                    <i class="bi bi-shield-lock"></i>
                    Aadhaar Card Number
                </label>

                <input asp-for="AadharCardNumber"
                    class="form-control"
                    maxlength="12"
                    placeholder="Leave blank to keep existing Aadhaar" />

                <span asp-validation-for="AadharCardNumber"
                    class="text-danger"></span>

                <small class="text-muted">
                    Leave blank if you do not want to change Aadhaar.
                </small>
            </div>

            <div class="mb-3">
                <label>
                    <i class="bi bi-person-vcard"></i>
                    PAN Card Number
                </label>

                <input asp-for="PanCardNumber"
                    class="form-control"
                    maxlength="10"
                    oninput="this.value = this.value.toUpperCase()"
                    placeholder="Leave blank to keep existing PAN" />

                <span asp-validation-for="PanCardNumber"
                    class="text-danger"></span>

                <small class="text-muted">
                    Leave blank if you do not want to change PAN.
                </small>
            </div>

                <div class="mb-3">
                    <label>Role</label>
                    <select asp-for="Role"
                            class="form-select">
                        <option>Admin</option>
                        <option>HR</option>
                        <option>Manager</option>
                        <option>User</option>
                    </select>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="IsActive"
                           class="form-check-input" />

                    <label asp-for="IsActive"
                           class="form-check-label">
                        Active
                    </label>
                </div>

                <button type="submit"
                        class="btn btn-warning">
                    Update
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Back
                </a>

            </form>

        </div>

    </div>

</div>