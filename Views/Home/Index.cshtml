@model EmployeeManagement.Models.DashboardViewModel
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Dashboard";

    bool mustChangePassword =
        Context.Session.GetString("MustChangePassword") == "True";
}

<div class="container-fluid mt-4 mb-4">

    <div class="dashboard-hero mb-4">

        <div>
            <h2 class="mb-1">
                Employee Management Dashboard
            </h2>

            <p class="text-muted mb-0">
                Overview of employees, departments, salary insights, and workforce analytics.
            </p>
        </div>

    </div>

    <div class="row g-4">

        <div class="col-xl-3 col-md-6">

            <a asp-controller="Employee"
               asp-action="Index"
               class="text-decoration-none">

                <div class="card dashboard-stat-card stat-primary">

                    <div class="card-body d-flex justify-content-between align-items-center">

                        <div>
                            <p class="stat-label">Total Employees</p>

                            <h2 class="stat-value">
                                @Model.TotalEmployees
                            </h2>
                        </div>

                        <div class="stat-icon">
                            <i class="bi bi-people-fill"></i>
                        </div>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-xl-3 col-md-6">

            <a asp-controller="Department"
               asp-action="Index"
               class="text-decoration-none">

                <div class="card dashboard-stat-card stat-success">

                    <div class="card-body d-flex justify-content-between align-items-center">

                        <div>
                            <p class="stat-label">Total Departments</p>

                            <h2 class="stat-value">
                                @Model.TotalDepartments
                            </h2>
                        </div>

                        <div class="stat-icon">
                            <i class="bi bi-building"></i>
                        </div>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-xl-3 col-md-6">

            <a asp-controller="Employee"
               asp-action="Index"
               asp-route-genderFilter="Male"
               class="text-decoration-none">

                <div class="card dashboard-stat-card stat-info">

                    <div class="card-body d-flex justify-content-between align-items-center">

                        <div>
                            <p class="stat-label">Male Employees</p>

                            <h2 class="stat-value">
                                @Model.MaleEmployees
                            </h2>
                        </div>

                        <div class="stat-icon">
                            <i class="bi bi-person-fill"></i>
                        </div>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-xl-3 col-md-6">

            <a asp-controller="Employee"
               asp-action="Index"
               asp-route-genderFilter="Female"
               class="text-decoration-none">

                <div class="card dashboard-stat-card stat-warning">

                    <div class="card-body d-flex justify-content-between align-items-center">

                        <div>
                            <p class="stat-label">Female Employees</p>

                            <h2 class="stat-value">
                                @Model.FemaleEmployees
                            </h2>
                        </div>

                        <div class="stat-icon">
                            <i class="bi bi-person-heart"></i>
                        </div>

                    </div>

                </div>

            </a>

        </div>

    </div>

    <div class="row g-4 mt-1">

        <div class="col-lg-6">

            <div class="card chart-card h-100">

                <div class="card-header bg-white d-flex justify-content-between align-items-center">

                    <h5 class="mb-0">
                        <i class="bi bi-bar-chart-fill text-primary"></i>
                        Employees By Department
                    </h5>

                </div>

                <div class="card-body">
                    <canvas id="departmentChart"></canvas>
                </div>

            </div>

        </div>

        <div class="col-lg-6">

            <div class="card chart-card h-100">

                <div class="card-header bg-white d-flex justify-content-between align-items-center">

                    <h5 class="mb-0">
                        <i class="bi bi-pie-chart-fill text-success"></i>
                        Gender Distribution
                    </h5>

                </div>

                <div class="card-body">
                    <canvas id="genderChart"></canvas>
                </div>

            </div>

        </div>

    </div>

    <div class="row g-4 mt-1">

        <div class="col-xl-3 col-md-6">

            <div class="card insight-card border-success h-100">

                <div class="card-body">

                    <div class="insight-icon text-success">
                        <i class="bi bi-arrow-up-circle"></i>
                    </div>

                    <p class="text-muted mb-1">
                        Highest Salary
                    </p>

                    <h6 class="fw-bold">
                        @Model.HighestSalaryEmployee
                    </h6>

                    <h5 class="mb-0">
                        ₹ @Model.HighestSalary.ToString("N2")
                    </h5>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card insight-card border-danger h-100">

                <div class="card-body">

                    <div class="insight-icon text-danger">
                        <i class="bi bi-arrow-down-circle"></i>
                    </div>

                    <p class="text-muted mb-1">
                        Lowest Salary
                    </p>

                    <h6 class="fw-bold">
                        @Model.LowestSalaryEmployee
                    </h6>

                    <h5 class="mb-0">
                        ₹ @Model.LowestSalary.ToString("N2")
                    </h5>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card insight-card border-primary h-100">

                <div class="card-body">

                    <div class="insight-icon text-primary">
                        <i class="bi bi-cash-stack"></i>
                    </div>

                    <p class="text-muted mb-1">
                        Average Salary
                    </p>

                    <h4 class="mb-0">
                        ₹ @Model.AverageSalary.ToString("N2")
                    </h4>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card insight-card border-warning h-100">

                <div class="card-body">

                    <div class="insight-icon text-warning">
                        <i class="bi bi-calendar-plus"></i>
                    </div>

                    <p class="text-muted mb-1">
                        Employees Added This Month
                    </p>

                    <h3 class="mb-0">
                        @Model.EmployeesAddedThisMonth
                    </h3>

                </div>

            </div>

        </div>

    </div>

</div>

@if (mustChangePassword)
{
    <div class="position-fixed bottom-0 end-0 p-3"
         style="z-index: 1055;">

        <div class="card shadow-lg border-0"
             style="width: 360px; border-radius: 16px;">

            <div class="card-header bg-warning text-dark fw-bold">

                <i class="bi bi-exclamation-triangle"></i>
                Password Reset Notice

            </div>

            <div class="card-body">

                <p class="mb-3">
                    Your password was reset by admin.
                    Do you want to change your password now?
                </p>

                <button type="button"
                        class="btn btn-primary btn-sm"
                        onclick="openForcePasswordModal()">

                    <i class="bi bi-check-circle"></i>
                    Yes

                </button>

                <button type="button"
                        class="btn btn-secondary btn-sm"
                        onclick="dismissPasswordPrompt(this)">

                    <i class="bi bi-x-circle"></i>
                    No

                </button>

            </div>

        </div>

    </div>
}

<div class="modal fade"
     id="forcePasswordModal"
     tabindex="-1">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header bg-primary text-white">

                <h5 class="modal-title">
                    <i class="bi bi-key"></i>
                    Change Password
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <form asp-controller="Account"
                  asp-action="ForceChangePassword"
                  method="post">

                @Html.AntiForgeryToken()

                <div class="modal-body">

                    <div class="mb-3">
                        <label>New Password</label>

                        <input name="NewPassword"
                               type="password"
                               class="form-control"
                               required
                               minlength="6" />
                    </div>

                    <div class="mb-3">
                        <label>Confirm Password</label>

                        <input name="ConfirmPassword"
                               type="password"
                               class="form-control"
                               required
                               minlength="6" />
                    </div>

                </div>

                <div class="modal-footer">

                    <button type="submit"
                            class="btn btn-primary">
                        <i class="bi bi-check-circle"></i>
                        Save Password
                    </button>

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>

        var departmentLabels =
            @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(
                    Model.DepartmentNames));

        var departmentCounts =
            @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(
                    Model.DepartmentCounts));

        new Chart(
            document.getElementById('departmentChart'),
            {
                type: 'bar',
                data:
                {
                    labels: departmentLabels,
                    datasets:
                    [{
                        label: 'Employees',
                        data: departmentCounts,
                        backgroundColor:
                        [
                            '#2563eb',
                            '#16a34a',
                            '#f59e0b',
                            '#dc2626',
                            '#7c3aed',
                            '#0891b2'
                        ],
                        borderRadius: 10,
                        borderSkipped: false
                    }]
                },
                options:
                {
                    responsive: true,
                    animation:
                    {
                        duration: 1200,
                        easing: 'easeOutQuart'
                    },
                    plugins:
                    {
                        legend:
                        {
                            display: false
                        },
                        tooltip:
                        {
                            backgroundColor: '#111827',
                            titleColor: '#ffffff',
                            bodyColor: '#e5e7eb',
                            padding: 12,
                            cornerRadius: 10
                        }
                    },
                    scales:
                    {
                        y:
                        {
                            beginAtZero: true,
                            ticks:
                            {
                                precision: 0
                            },
                            grid:
                            {
                                color: '#e5e7eb'
                            }
                        },
                        x:
                        {
                            grid:
                            {
                                display: false
                            }
                        }
                    }
                }
            });

        var genderLabels =
            @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(
                    Model.GenderLabels));

        var genderCounts =
            @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(
                    Model.GenderCounts));

        new Chart(
            document.getElementById('genderChart'),
            {
                type: 'doughnut',
                data:
                {
                    labels: genderLabels,
                    datasets:
                    [{
                        data: genderCounts,
                        backgroundColor:
                        [
                            '#2563eb',
                            '#ec4899',
                            '#f59e0b'
                        ],
                        borderColor: '#ffffff',
                        borderWidth: 4,
                        hoverOffset: 12
                    }]
                },
                options:
                {
                    responsive: true,
                    cutout: '65%',
                    animation:
                    {
                        animateRotate: true,
                        animateScale: true,
                        duration: 1200
                    },
                    plugins:
                    {
                        legend:
                        {
                            position: 'bottom',
                            labels:
                            {
                                usePointStyle: true,
                                padding: 20
                            }
                        },
                        tooltip:
                        {
                            backgroundColor: '#111827',
                            titleColor: '#ffffff',
                            bodyColor: '#e5e7eb',
                            padding: 12,
                            cornerRadius: 10
                        }
                    }
                }
            });

            function dismissPasswordPrompt(button) {
                const popup =
                    button.closest(".position-fixed");

                if (popup) {
                    popup.remove();
                }
            }

            function openForcePasswordModal() {
                var modal =
                    new bootstrap.Modal(
                        document.getElementById("forcePasswordModal"));

                modal.show();
            }

    </script>
}